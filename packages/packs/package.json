{
  "name": "@agentjeff/packs",
  "version": "0.1.0",
  "description": "Domain packs for agentjeff: workspace-pack, extraction-pack",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {
    "@agentjeff/core": "*",
    "@agentjeff/sdk": "*",
    "@agentjeff/adapters": "*"
  },
  "peerDependencies": {
    "openai": "^4.0.0",
    "zod": "^3.22.0"
  },
  "keywords": [
    "agent",
    "packs",
    "workspace",
    "agentjeff"
  ],
  "author": "Agent Jeff",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelmanly/agentjeff.git",
    "directory": "packages/packs"
  },
  "homepage": "https://github.com/michaelmanly/agentjeff#readme",
  "bugs": {
    "url": "https://github.com/michaelmanly/agentjeff/issues"
  }
}

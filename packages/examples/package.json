{
  "name": "@agentjeff/examples",
  "version": "0.1.0",
  "description": "Example agents for agentjeff: workspace assistant, structured extraction",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "dependencies": {
    "@agentjeff/sdk": "*",
    "@agentjeff/adapters": "*"
  },
  "peerDependencies": {
    "openai": "^4.0.0",
    "zod": "^3.22.0"
  },
  "keywords": [
    "agent",
    "examples",
    "agentjeff"
  ],
  "private": true
}

{
  "name": "@newatom/cli",
  "version": "0.1.0",
  "description": "CLI for newatom — run agents, inspect events, run tests",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "newatom": "./dist/index.js" },

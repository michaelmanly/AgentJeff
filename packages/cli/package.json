  "files": ["dist"],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@newatom/sdk": "*",
    "@newatom/examples": "*",
    "@newatom/adapters": "*"
  },
  "peerDependencies": {
    "commander": "^11.0.0",
    "openai": "^4.0.0",
    "zod": "^3.22.0"
  },
  "keywords": ["agent", "cli", "newatom"]
}

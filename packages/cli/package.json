{
  "name": "@agentjeff/cli",
  "version": "0.1.0",
  "description": "CLI for agentjeff \u2014 run agents, inspect events, run tests",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentjeff": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@agentjeff/sdk": "*",
    "@agentjeff/examples": "*",
    "@agentjeff/adapters": "*"
  },
  "peerDependencies": {
    "commander": "^11.0.0",
    "openai": "^4.0.0",
    "zod": "^3.22.0"
  },
  "keywords": [
    "agent",
    "cli",
    "agentjeff"
  ],
  "author": "Agent Jeff",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelmanly/agentjeff.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/michaelmanly/agentjeff#readme",
  "bugs": {
    "url": "https://github.com/michaelmanly/agentjeff/issues"
  }
}

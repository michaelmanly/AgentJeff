{
  "name": "@agentjeff/testing",
  "version": "0.1.0",
  "description": "Test harness for agentjeff agents: MockInferenceAdapter, runAndAssert, scenario runner",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "dependencies": {
    "@agentjeff/core": "*",
    "@agentjeff/runtime": "*"
  },
  "keywords": [
    "agent",
    "agent-testing",
    "mock-llm",
    "testing",
    "deterministic",
    "test-harness",
    "mock",
    "typescript",
    "agentjeff"
  ],
  "author": "Agent Jeff",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelmanly/agentjeff.git",
    "directory": "packages/testing"
  },
  "homepage": "https://github.com/michaelmanly/agentjeff#readme",
  "bugs": {
    "url": "https://github.com/michaelmanly/agentjeff/issues"
  }
}

{
  "name": "@newatom/workflow",
  "version": "0.1.0",
  "description": "Step-based workflow builder for newatom agents",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {
    "@newatom/core": "*",
    "@newatom/runtime": "*"
  },
  "keywords": ["agent", "workflow", "newatom"]
}

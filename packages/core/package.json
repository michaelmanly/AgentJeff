{
  "name": "@agentjeff/core",
  "version": "0.1.0",
  "description": "Domain-agnostic agent execution primitives: Agent, Run, State, Tool, Adapter, Event, Policy",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "ai-agent",
    "agent-runtime",
    "typescript",
    "types",
    "agent-framework",
    "agentjeff"
  ],
  "author": "Agent Jeff",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelmanly/agentjeff.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/michaelmanly/agentjeff#readme",
  "bugs": {
    "url": "https://github.com/michaelmanly/agentjeff/issues"
  }
}

{
  "name": "@newatom/core",
  "version": "0.1.0",
  "description": "Domain-agnostic agent execution primitives: Agent, Run, State, Tool, Adapter, Event, Policy",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "keywords": ["agent", "llm", "ai", "runtime", "newatom"]
}

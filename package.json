{
  "name": "agentjeff",
  "private": false,
  "scripts": {
    "test": "jest --testPathPattern='packages/runtime/src/__tests__'",
    "test:scenarios": "tsx packages/testing/src/run-scenarios.ts",
    "demo": "tsx scripts/demo.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "zod": "^3.22.0",
    "openai": "^4.0.0",
    "commander": "^11.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@agentjeff/core$": "<rootDir>/packages/core/src/index.ts",
      "^@agentjeff/runtime$": "<rootDir>/packages/runtime/src/index.ts",
      "^@agentjeff/testing$": "<rootDir>/packages/testing/src/index.ts",
      "^@agentjeff/adapters$": "<rootDir>/packages/adapters/src/index.ts",
      "^@agentjeff/workflow$": "<rootDir>/packages/workflow/src/index.ts",
      "^@agentjeff/packs$": "<rootDir>/packages/packs/src/index.ts"
    },
    "extensionsToTreatAsEsm": [],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": false
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  },
  "version": "0.1.0",
  "description": "AgentJeff npm SDK — defineAgent, defineTool, and run() with built-in runtime and adapters",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "zod-to-json-schema": "^3.23.0"
  },
  "peerDependencies": {
    "openai": "^4.0.0",
    "zod": "^3.22.0"
  }
}
